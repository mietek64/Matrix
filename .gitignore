# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
MANIFEST

# ── PyInstaller build output — never commit these ─────────────────────────────
build/
dist/
*.spec

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env/

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Personal config overrides (the config.json in the repo root is the
#    default template — personal saves go to APPDATA/matrix, not here) ─────────
local_config.json
my_config.json
*.theme.json
presets.json
